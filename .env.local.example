# Copy this file to .env.local and fill in the values.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Must exactly match a "Valid OAuth Redirect URI" registered in the
# Instagram Business Login settings (no trailing slash).
SITE_URL=http://localhost:3000

# Instagram App ID/Secret from: App Dashboard > Casos de uso > "Gerenciar
# mensagens e conteúdo no Instagram" > Configuração da API com login do
# Instagram. NOT the same as the app's main App ID/Secret.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# 32 raw bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIALS_ENCRYPTION_KEY=
